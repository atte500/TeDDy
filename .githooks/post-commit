#!/bin/sh
#
# Post-commit hook: Mandatory full test suite gate
#
# Runs after every `git commit`. If tests fail, the commit is reverted
# while preserving all staged changes. This hook is NOT affected by
# `--no-verify`, making it the only truly unskippable test gate.
#
# Dependencies: poetry run pytest (project's test runner)
#

# Pre-flight: ensure poetry is installed
if ! command -v poetry >/dev/null 2>&1; then
    echo ""
    echo "============================================"
    echo " ERROR: poetry is not installed"
    echo "============================================"
    echo "Install poetry to run the test suite."
    echo "  curl -sSL https://install.python-poetry.org | python3 -"
    echo ""
    echo "The commit has been undone. Fix the dependency and re-commit."
    echo "============================================"
    echo ""
    git reset --soft HEAD~1
    exit 1
fi

# Pre-flight: ensure pytest is available in the poetry environment
if ! poetry run python -c "import pytest" >/dev/null 2>&1; then
    echo ""
    echo "============================================"
    echo " ERROR: pytest is not installed in the poetry environment"
    echo "============================================"
    echo "Run 'poetry install --with dev' to install test dependencies."
    echo ""
    echo "The commit has been undone. Fix the dependency and re-commit."
    echo "============================================"
    echo ""
    git reset --soft HEAD~1
    exit 1
fi

# Run the full test suite (do NOT use set -e; capture exit code explicitly)
poetry run pytest --tb=short -q 2>&1

# Capture exit code
EXIT_CODE=$?

if [ $EXIT_CODE -ne 0 ]; then
    echo ""
    echo "============================================"
    echo " TESTS FAILED — Reverting commit"
    echo "============================================"
    echo "The commit has been undone to prevent red state."
    echo "Your changes remain staged. Fix the tests and re-commit."
    echo "============================================"
    echo ""
    git reset --soft HEAD~1
    exit 1
fi

exit 0
